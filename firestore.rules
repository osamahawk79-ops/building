rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'osamahawk3@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation functions
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.username is string && data.username.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role is string && (data.role == 'user' || data.role == 'admin')
        && data.subscription is string && (data.subscription == 'none' || data.subscription == 'bronze' || data.subscription == 'gold')
        && data.subscriptionStatus is string && (data.subscriptionStatus == 'none' || data.subscriptionStatus == 'pending' || data.subscriptionStatus == 'active' || data.subscriptionStatus == 'blocked');
    }

    function isValidCategory(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100;
    }

    function isValidLecture(data) {
      return data.id is string && data.id.size() <= 128
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.videoUrl is string && data.videoUrl.size() <= 500
        && data.videoProvider is string && (data.videoProvider == 'bunny' || data.videoProvider == 'vimeo' || data.videoProvider == 'youtube' || data.videoProvider == 'raw')
        && data.tierRequired is string && (data.tierRequired == 'free' || data.tierRequired == 'bronze' || data.tierRequired == 'gold');
    }

    function isValidSettings(data) {
      return data.siteName is string && data.siteName.size() <= 100;
    }

    // Rules matching
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && (
        incoming().role == 'user' || 
        (request.auth.token.email == 'osamahawk3@gmail.com' && incoming().role == 'admin')
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (
          userId == request.auth.uid && 
          isValidUser(incoming()) && 
          incoming().role == existing().role && 
          incoming().subscription == existing().subscription && 
          (
            incoming().subscriptionStatus == existing().subscriptionStatus || 
            incoming().subscriptionStatus == 'pending'
          ) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['username', 'paymentTxInfo', 'subscriptionStatus', 'pendingSubscriptionType'])
        )
      );
      
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if (isAdmin() || !exists(/databases/$(database)/documents/categories/$(categoryId))) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /lectures/{lectureId} {
      allow read: if true;
      allow create: if (isAdmin() || !exists(/databases/$(database)/documents/lectures/$(lectureId))) && isValidLecture(incoming());
      allow update: if isAdmin() && isValidLecture(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow create: if (isAdmin() || !exists(/databases/$(database)/documents/settings/site_config)) && isValidSettings(incoming());
      allow update: if isAdmin() && isValidSettings(incoming());
      allow delete: if isAdmin();
    }
  }
}
