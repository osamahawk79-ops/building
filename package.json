{
  "name": "react-example",
  "private": true,
  "version": "2.0.0-rc1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"tsx server/index.ts\" \"npx vite\"",
    "server": "tsx server/index.ts",
    "vite": "npx vite",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild electron/main.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/electron/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/electron/preload.cjs",
    "start": "cross-env NODE_ENV=production node dist/server.cjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen-ico": "png-to-ico assets/icon.png assets/icon.ico",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "electron-builder --dir",
    "pack:deploy": "node scripts/pack-deploy.js"
  },
  "main": "dist/electron/main.cjs",
  "build": {
    "appId": "com.buildingmakers.lms",
    "productName": "LMS-Platform",
    "copyright": "Building Makers © 2026",
    "files": [
      "dist/**/*",
      "data/**/*",
      "storage/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "directories": {
      "output": "dist/electron-build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "LMS-Platform-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "LMS Platform"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.15.0",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.18.1",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "png-to-ico": "^3.0.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "@google/genai@2.10.0": true,
    "electron-winstaller@5.4.0": true,
    "protobufjs@7.6.4": true
  }
}
